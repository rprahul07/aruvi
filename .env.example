# ────────────────────────────────────────────────────────────
# AURVI commerce platform — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already in .gitignore.
# ────────────────────────────────────────────────────────────

# --- App -------------------------------------------------------
# NOTE: Do NOT set NODE_ENV yourself. Next.js manages it automatically
# (development for `next dev`, production for `next build`/`next start`).
# Forcing NODE_ENV=development in a build environment (e.g. Netlify/Vercel)
# breaks the production React build — "Cannot read properties of null
# (reading 'useState')" during prerender.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key: server-only, NEVER expose via NEXT_PUBLIC_*, never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (configured as a provider inside Supabase Auth) ---
# Set these in Supabase Dashboard -> Authentication -> Providers -> Google.
# Kept here too so the same client ID can be reused if you ever need it in code.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- Razorpay ------------------------------------------------------
# Test-mode keys from Razorpay Dashboard -> Settings -> API Keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Dashboard -> Webhooks -> your webhook -> Secret. Used to verify webhook signatures.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Public key id only, safe to expose to the browser for Razorpay Checkout.js
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# --- Cron / scheduled jobs ------------------------------------------
# Shared secret for the reservation-sweep cron endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-long-random-cron-secret

# --- Analytics (optional, app must run fine with this unset) ---------
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Store defaults (used by seed data / settings fallback) -----------
STORE_DEFAULT_CURRENCY=INR
STORE_DEFAULT_TAX_PERCENT=3
